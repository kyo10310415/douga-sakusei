# Database
DATABASE_URL=postgresql://vtuber:vtuber_pass@localhost:5432/vtuber_studio
POSTGRES_USER=vtuber
POSTGRES_PASSWORD=vtuber_pass
POSTGRES_DB=vtuber_studio

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# YouTube OAuth
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# TTS (text-to-speech)
# Providers: openai | elevenlabs | voicevox | mock
TTS_PROVIDER=mock
TTS_API_KEY=your-tts-api-key
VOICEVOX_URL=http://localhost:50021

# Image Generation
# Providers: openai | stability | mock
IMAGE_GENERATION_PROVIDER=mock
IMAGE_GENERATION_API_KEY=your-image-generation-api-key

# Video Generation
# Providers: heygen | did | runway | mock
VIDEO_GENERATION_PROVIDER=mock
VIDEO_GENERATION_API_KEY=your-video-generation-api-key

# Storage
# Providers: local | s3 | gcs
STORAGE_PROVIDER=local
STORAGE_BUCKET=vtuber-uploads
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_BASE_URL=http://localhost:8000/static

# App Settings
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
